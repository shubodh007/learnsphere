# LearnSphere AI - Environment Variables
# Copy this file to .env and fill in your actual values

# ==============================================================================
# FRONTEND ENVIRONMENT VARIABLES (Required for local development)
# ==============================================================================
# These are exposed to the browser via Vite (prefixed with VITE_)
# Get these from your Supabase project: https://supabase.com/dashboard/project/_/settings/api

# Your Supabase project URL
# Example: https://abcdefghijklmnop.supabase.co
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anonymous/public API key (safe to expose to browser)
# Found in: Project Settings > API > Project API keys > anon public
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ==============================================================================
# BACKEND ENVIRONMENT VARIABLES (For Supabase Edge Functions)
# ==============================================================================
# These should NOT be in your .env file - they are managed separately!
# Set these as Supabase secrets using the CLI or dashboard:
#   - CLI: supabase secrets set OPENROUTER_API_KEY=your-key
#   - Dashboard: Project Settings > Edge Functions > Secrets

# SUPABASE_URL (automatically provided by Supabase runtime)
# SUPABASE_SERVICE_ROLE_KEY (automatically provided by Supabase runtime)

# OpenRouter API key for AI model access (generate-lesson, chat, generate-code)
# Get your key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key

# Optional: Anthropic API key for premium lesson quiz generation.
# If omitted, the quiz function falls back to the existing OpenRouter-backed stack.
ANTHROPIC_API_KEY=your-anthropic-api-key
# YouTube Data API v3 key for video search (youtube-search function)
# Get your key from: https://console.cloud.google.com/apis/credentials
# Enable the YouTube Data API v3: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=your-youtube-api-key

# ==============================================================================
# SETUP INSTRUCTIONS
# ==============================================================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY from Supabase dashboard
# 3. Get OpenRouter API key from https://openrouter.ai/keys
# 4. Get YouTube API key from https://console.cloud.google.com/apis/credentials
# 5. Set backend secrets via Supabase CLI:
#    supabase secrets set OPENROUTER_API_KEY=your-key
#    supabase secrets set YOUTUBE_API_KEY=your-key
# 6. Deploy edge functions: supabase functions deploy
